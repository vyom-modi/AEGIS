# ===== AEGIS Environment Configuration =====

# --- LLM Configuration ---
# Provider: groq (default)
LLM_PROVIDER=groq
# Model name (must be compatible with the provider)
LLM_MODEL=llama-3.3-70b-versatile

# --- Groq ---
GROQ_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# --- E2B Sandbox (optional, for cloud code execution) ---
E2B_API_KEY=

# --- LangSmith (optional, for tracing) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aegis
